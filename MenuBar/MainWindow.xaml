<Window x:Class="MenuBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MenuBar"
        xmlns:UserControls ="clr-namespace:MenuBar.View.UserControls"
        mc:Ignorable="d"
        Title="MainWindow" Height="145" Width="800">
    <Grid ShowGridLines="True" Margin="0,0,0,-1">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition />
            <RowDefinition Height="20" />

        </Grid.RowDefinitions>
        <UserControls:MenuBar />

        <Rectangle Fill="LightGray" Grid.Row="2" />

    </Grid>
</Window>
